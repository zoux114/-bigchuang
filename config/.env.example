# LLM API 配置 (必填)
LLM_API_KEY=your_api_password_or_AK:SK
LLM_BASE_URL=https://spark-api-open.xf-yun.com/v2/
LLM_MODEL=spark-x

# 向量索引目录 (可选，建议单独目录)
# 示例相对路径: data/vector_precomputed
# 示例绝对路径: /opt/rag/vector_precomputed
VECTOR_DB_DIR=data/vector_precomputed

# 说明: 讯飞 X1.5 兼容 OpenAI SDK
# - APIpassword 可直接作为 LLM_API_KEY
# - 或使用 ws 协议的 AK:SK 拼接形式作为 LLM_API_KEY
# - 对应 model 为 spark-x

# 可选: 智谱 AI
# LLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
# LLM_MODEL=glm-4
